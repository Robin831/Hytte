}\n   400→          <section className=\"bg-gray-800 rounded-xl p-6 mb-6\">\n   401→            <div className=\"flex items-center justify-between\">\n   402→              <div>\n   403→                <p className=\"text-sm text-gray-400 mb-1\">Right now in {location}</p>\n   404→                <div className=\"flex items-end gap-3\">\n   405→                  <span className=\"text-5xl font-bold\">\n   406→                    {Math.round(current.data.instant.details.air_temperature)}°\n   407→                  </span>\n   408→                  <span className=\"text-lg text-gray-300 mb-1\">\n   409→                    {getWeatherDescription(currentSymbol)}\n   410→                  </span>\n   411→                </div>\n   412→              </div>\n   413→              <div className=\"text-blue-400\">\n   414→                {getWeatherIcon(currentSymbol, 56)}\n   415→              </div>\n   416→            </div>\n   417→\n   418→            <div className=\"grid grid-cols-3 gap-4 mt-6 pt-4 border-t border-gray-700\">\n   419→              <div className=\"flex items-center gap-2\">\n   420→                <Wind size={16} className=\"text-gray-400\" />\n   421→                <div>\n   422→                  <p className=\"text-xs text-gray-400\">Wind</p>\n   423→                  <p className=\"text-sm font-medium\">\n   424→                    {current.data.instant.details.wind_speed} m/s\n   425→                  </p>\n   426→                </div>\n   427→              </div>\n   428→              <div className=\"flex items-center gap-2\">\n   429→                <Droplets size={16} className=\"text-gray-400\" />\n   430→                <div>\n   431→                  <p className=\"text-xs text-gray-400\">Humidity</p>\n   432→                  <p className=\"text-sm font-medium\">\n   433→                    {Math.round(current.data.instant.details.relative_humidity)}%\n   434→                  </p>\n   435→                </div>\n   436→              </